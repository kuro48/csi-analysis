        <mxCell id="proof-gen" value="&lt;b&gt;証明生成&lt;/b&gt;&lt;br&gt;(snarkjs Groth16)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="920" y="330" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="proof-gen-content" value="• R1CS制約システム&lt;br&gt;• Witness計算&lt;br&gt;• Groth16証明生成&lt;br&gt;• 処理時間: ~100ms" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;" vertex="1" parent="1">
