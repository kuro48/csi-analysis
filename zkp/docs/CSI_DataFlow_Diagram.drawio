        <mxCell id="title" value="CSIサブキャリア選択システム - データフロー図" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="20" width="520" height="40" as="geometry" />
        </mxCell>

        <!-- ========== フェーズ1: データ取得 ========== -->
        <mxCell id="phase1-label" value="フェーズ1: CSIデータ取得" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- エッジデバイス -->
        <mxCell id="edge-device" value="&lt;b&gt;エッジデバイス&lt;/b&gt;&lt;br&gt;(ESP32 + CSI取得)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="edge-device-content" value="• Wi-Fi CSI測定&lt;br&gt;• 56サブキャリア&lt;br&gt;• 振幅・位相データ&lt;br&gt;• サンプリング: 100Hz" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="155" width="180" height="65" as="geometry" />
        </mxCell>

        <!-- 生CSIデータ -->
        <mxCell id="raw-csi" value="&lt;b&gt;生CSIデータ&lt;/b&gt;&lt;br&gt;JSON形式" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="140" width="120" height="80" as="geometry" />
        </mxCell>

        <mxCell id="arrow1" value="HTTP POST&lt;br&gt;/api/v2/csi-data/upload" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="edge-device" target="raw-csi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== フェーズ2: 前処理 ========== -->
        <mxCell id="phase2-label" value="フェーズ2: 前処理・正規化" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- 前処理モジュール -->
        <mxCell id="preprocessing" value="&lt;b&gt;前処理モジュール&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="500" y="130" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="preprocessing-content" value="1. ノイズ除去&lt;br&gt;2. 振幅正規化&lt;br&gt;3. サブキャリア選択候補抽出&lt;br&gt;4. 固定小数点変換 (×10⁴)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="155" width="180" height="65" as="geometry" />
        </mxCell>

        <mxCell id="arrow2" value="CSIデータ" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="raw-csi" target="preprocessing">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== フェーズ3: コサイン類似度計算 (Witness生成) ========== -->
        <mxCell id="phase3-label" value="フェーズ3: Witness生成" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- Witness計算モジュール -->
        <mxCell id="witness-calc" value="&lt;b&gt;Witness計算&lt;/b&gt;&lt;br&gt;(JavaScript)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="280" height="140" as="geometry" />
        </mxCell>

        <mxCell id="witness-calc-content" value="&lt;b&gt;ステップ1: ベクトル準備&lt;/b&gt;&lt;br&gt;• 参照ベクトル (4次元)&lt;br&gt;• 候補ベクトル群 (2個 × 4次元)&lt;br&gt;&lt;br&gt;&lt;b&gt;ステップ2: 計算&lt;/b&gt;&lt;br&gt;• ノルム計算: ||A|| = √(Σ Ai²)&lt;br&gt;• 内積計算: A·B = Σ(Ai × Bi)&lt;br&gt;• 類似度: cos_sim = (A·B × 10⁴) / (||A|| × ||B||)&lt;br&gt;&lt;br&gt;&lt;b&gt;ステップ3: Witness JSON出力&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="355" width="260" height="105" as="geometry" />
        </mxCell>

        <mxCell id="arrow3" value="正規化済み&lt;br&gt;CSIベクトル" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="preprocessing" target="witness-calc">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset" />
            <Array as="points">
              <mxPoint x="600" y="260" />
              <mxPoint x="180" y="260" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Witness JSON -->
        <mxCell id="witness-json" value="&lt;b&gt;Witness JSON&lt;/b&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;size=15;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="330" width="160" height="140" as="geometry" />
        </mxCell>

        <mxCell id="witness-json-content" value="{&lt;br&gt;  reference: [8500, ...],&lt;br&gt;  candidates: [[...], [...]],&lt;br&gt;  referenceNorm: 11747,&lt;br&gt;  candidateNorms: [...],&lt;br&gt;  similarities: [9990, 8281]&lt;br&gt;}" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="390" y="355" width="140" height="105" as="geometry" />
        </mxCell>

        <mxCell id="arrow4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" parent="1" source="witness-calc" target="witness-json">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== フェーズ4: ZKP回路処理 ========== -->
        <mxCell id="phase4-label" value="フェーズ4: ZKP回路処理" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="280" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- Circom回路 -->
        <mxCell id="circom-circuit" value="&lt;b&gt;Circom回路&lt;/b&gt;&lt;br&gt;csi_subcarrier_selector.circom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="circom-circuit-content" value="&lt;b&gt;1. DotProduct(N=4)&lt;/b&gt;&lt;br&gt;   A·B = Σ(Ai × Bi)&lt;br&gt;&lt;br&gt;&lt;b&gt;2. VectorNorm(N=4)&lt;/b&gt;&lt;br&gt;   ||A||² = Σ(Ai²)&lt;br&gt;&lt;br&gt;&lt;b&gt;3. CosineSimilarityVerified&lt;/b&gt;&lt;br&gt;   検証: sim × ||A|| × ||B|| === A·B × 10⁴&lt;br&gt;&lt;br&gt;&lt;b&gt;4. SubcarrierSelector&lt;/b&gt;&lt;br&gt;   最大類似度の候補を選択&lt;br&gt;   閾値チェック (≥ 0.7)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="610" y="355" width="240" height="105" as="geometry" />
        </mxCell>

        <mxCell id="arrow5" value="Witness入力" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;" edge="1" parent="1" source="witness-json" target="circom-circuit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== フェーズ5: 証明生成 ========== -->
        <mxCell id="phase5-label" value="フェーズ5: 証明生成" style="text;html=1;strokeColor=none;fillColor=#e1d5e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="900" y="280" width="200" height="30" as="geometry" />
        </mxCell>

