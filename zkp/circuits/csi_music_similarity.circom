pragma circom 2.0.0;

include "circomlib/circuits/comparators.circom";

/**
 * CSI呼吸モニタリング ZKP 回路（MUSIC法 - ノイズ部分空間版）
 *
 * 設計方針:
 *   秘密入力: ノイズ部分空間行列 en[L][K]
 *            （Python の np.linalg.eigh で計算した固有ベクトル、×EN_SCALE=1000 整数化）
 *   公開出力: isNormal
 *
 * 回路内で行うこと:
 *   1. MUSIC 疑似スペクトル分母を計算:
 *        v_cos[f][k] = Σ_m en[m][k] × COS_STEER[f][m]  (整数余弦ステアリングベクトル)
 *        v_sin[f][k] = Σ_m en[m][k] × SIN_STEER[f][m]
 *        P_inv[f] = Σ_k (v_cos[f][k]² + v_sin[f][k]²)   (疑似スペクトルの逆数に比例)
 *   2. argmin(P_inv) → MUSIC ピーク周波数ビン
 *   3. ピークが [NORMAL_LOW_BIN, NORMAL_HIGH_BIN] 内 → isNormal = 1
 *
 * ビット幅 (EN_SCALE=1000, STEER_SCALE=1000, L=32, K=30):
 *   max|v| = √L × EN_SCALE × STEER_SCALE / STEER_SCALE ≈ 32×1e6 = 3.2×10⁷ < 2^25
 *   v² < 2^50;  P_inv < 30×2×2^50 < 2^57  → LessThan(57) を使用
 *
 * ステアリングベクトル仕様 (Fs=5.0Hz):
 *   COS_STEER[f][m] = round(cos(2π × (0.155 + f×0.01) × m / 5.0) × 1000)
 *   SIN_STEER[f][m] = round(sin(2π × (0.155 + f×0.01) × m / 5.0) × 1000)
 *
 * 周波数マッピング (0.01Hz刻みビン):
 *   bin  0 → 0.155Hz ≈ 0.15Hz  ← NORMAL_LOW_BIN
 *   bin 35 → 0.505Hz ≈ 0.50Hz  ← NORMAL_HIGH_BIN
 *   bin 44 → 0.595Hz ≈ 0.60Hz
 */

