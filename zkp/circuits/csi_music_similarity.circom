    [0, 572, 939, 967, 647, 94, -493, -902, -987, -716, -187, 409, 858, 998, 778, 279, -321, -805, -1000, -834, -368, 230, 746, 993, 882, 454, -138, -680, -977, -923, -536, 44],
    [0, 583, 947, 957, 608, 31, -557, -937, -965, -633, -63, 531, 925, 973, 657, 94, -504, -913, -980, -680, -125, 476, 899, 986, 703, 156, -448, -885, -990, -725, -187, 420],
    [0, 593, 955, 945, 567, -31, -618, -964, -934, -541, 63, 642, 972, 923, 514, -94, -666, -979, -910, -487, 125, 689, 985, 897, 460, -156, -712, -990, -882, -431, 187, 733],
    [0, 603, 962, 932, 525, -94, -675, -983, -894, -443, 187, 742, 996, 848, 356, -279, -802, -1000, -794, -267, 368, 854, 995, 733, 175, -454, -899, -981, -666, -82, 536, 937],
    [0, 613, 969, 918, 482, -156, -729, -996, -844, -339, 309, 827, 998, 750, 187, -454, -905, -976, -637, -31, 588, 960, 930, 509, -125, -707, -992, -861, -368, 279, 809, 1000],
    [0, 623, 975, 902, 437, -218, -778, -1000, -786, -230, 426, 897, 977, 633, 13, -613, -972, -907, -448, 206, 771, 1000, 794, 243, -414, -891, -980, -642, -25, 603, 969, 913],
    [0, 633, 980, 885, 391, -279, -824, -997, -720, -119, 536, 949, 934, 498, -163, -750, -999, -798, -236, 431, 905, 970, 598, -44, -666, -988, -864, -351, 321, 848, 992, 689],
    [0, 642, 985, 867, 345, -339, -864, -986, -647, -6, 637, 983, 870, 351, -333, -861, -987, -652, -13, 633, 982, 873, 356, -327, -858, -988, -657, -19, 628, 981, 876, 362],
    [0, 652, 989, 848, 297, -397, -899, -967, -567, 107, 729, 999, 786, 194, -493, -941, -934, -476, 212, 798, 998, 716, 88, -583, -972, -891, -380, 315, 858, 986, 637, -19],
    [0, 661, 992, 827, 249, -454, -930, -941, -482, 218, 809, 996, 685, 31, -637, -988, -844, -279, 426, 918, 951, 509, -187, -790, -998, -707, -63, 613, 982, 861, 309, -397],
    [0, 671, 995, 805, 200, -509, -955, -907, -391, 327, 876, 973, 567, -132, -762, -1000, -720, -69, 618, 986, 844, 267, -448, -932, -934, -454, 261, 841, 987, 623, -63, -716],
    [0, 680, 997, 782, 150, -562, -975, -867, -297, 431, 930, 932, 437, -291, -864, -976, -567, 144, 778, 998, 685, 6, -675, -997, -786, -156, 557, 973, 870, 303, -426, -927]
];

    signal v_cos[NUM_FREQ][K];
    signal v_sin[NUM_FREQ][K];
    signal v_cos_sq[NUM_FREQ][K];
    signal v_sin_sq[NUM_FREQ][K];
    signal pinv_partial[NUM_FREQ][K];
    signal pinv[NUM_FREQ];

    for (var f = 0; f < NUM_FREQ; f++) {
        for (var k = 0; k < K; k++) {
            var vc = 0;
            var vs = 0;
            for (var m = 0; m < L; m++) {
                vc += COS_STEER[f][m] * en[m][k];
                vs += SIN_STEER[f][m] * en[m][k];
            }
            v_cos[f][k] <== vc;
            v_sin[f][k] <== vs;
            v_cos_sq[f][k] <== v_cos[f][k] * v_cos[f][k];
            v_sin_sq[f][k] <== v_sin[f][k] * v_sin[f][k];

            if (k == 0) {
                pinv_partial[f][0] <== v_cos_sq[f][0] + v_sin_sq[f][0];
            } else {
                pinv_partial[f][k] <== pinv_partial[f][k-1] + v_cos_sq[f][k] + v_sin_sq[f][k];
            }
        }
        pinv[f] <== pinv_partial[f][K-1];
    }

    // ===== argmin(P_inv) = MUSIC ピーク =====
    signal minPinv[NUM_FREQ];
    signal minIdx[NUM_FREQ];
    signal pinv_term_a[NUM_FREQ];
    signal pinv_term_b[NUM_FREQ];
    signal midx_term_b[NUM_FREQ];
    component lt[NUM_FREQ];

    minPinv[0]      <== pinv[0];
    minIdx[0]       <== 0;
    pinv_term_a[0]  <== 0;
    pinv_term_b[0]  <== 0;
    midx_term_b[0]  <== 0;

    for (var f = 1; f < NUM_FREQ; f++) {
        lt[f] = LessThan(57);
        lt[f].in[0] <== pinv[f];
        lt[f].in[1] <== minPinv[f-1];

        pinv_term_a[f] <== lt[f].out * pinv[f];
        pinv_term_b[f] <== lt[f].out * minPinv[f-1];
        minPinv[f] <== pinv_term_a[f] - pinv_term_b[f] + minPinv[f-1];

        midx_term_b[f] <== lt[f].out * minIdx[f-1];
        minIdx[f] <== f * lt[f].out - midx_term_b[f] + minIdx[f-1];
    }

    // ===== 正常範囲チェック =====
    component geLow = GreaterEqThan(8);
    geLow.in[0] <== minIdx[NUM_FREQ-1];
    geLow.in[1] <== NORMAL_LOW_BIN;

    component leHigh = LessEqThan(8);
    leHigh.in[0] <== minIdx[NUM_FREQ-1];
    leHigh.in[1] <== NORMAL_HIGH_BIN;

    isNormal <== geLow.out * leHigh.out;
}

/**
 * パラメータ:
 *   L              = 32  (MUSIC_EMBEDDING_DIM, Hankel 行列の埋め込み次元)
 *   K              = 30  (ノイズ固有ベクトル数 = L - MUSIC_MODEL_ORDER = 32 - 2)
 *   NUM_FREQ       = 45  (0.15〜0.60Hz, 0.01Hz刻み)
 *   NORMAL_LOW_BIN = 0   (0.155Hz ≈ 0.15Hz)
 *   NORMAL_HIGH_BIN= 35  (0.505Hz ≈ 0.50Hz)
 */
component main = MUSICNoiseSubspaceCheck(32, 30, 45, 0, 35);
