pragma circom 2.0.0;

include "circomlib/circuits/comparators.circom";

/**
 * CSI呼吸モニタリング ZKP 回路（ウェーブレット版 - DFT近似）
 *
 * 設計方針:
 *   秘密入力: 平均化された時系列 CSI 振幅 avg_csi[T]
 *            （T=150 サンプル, Fs=5.0Hz, デトレンド・min-max正規化・ZKP_SCALE倍済み）
 *   公開出力: isNormal
 *
 * 回路内で行うこと:
 *   1. DFT近似でパワースペクトル計算:
 *        X_cos[f] = Σ_t avg_csi[t] × COS_TABLE[f][t]  (整数余弦テーブル)
 *        X_sin[f] = Σ_t avg_csi[t] × SIN_TABLE[f][t]
 *        power[f] = X_cos[f]² + X_sin[f]²
 *   2. argmax(power) → ピーク周波数ビン
 *   3. ピークが [NORMAL_LOW_BIN, NORMAL_HIGH_BIN] 内 → isNormal = 1
 *
 * ビット幅 (ZKP_SCALE=100, COS_SCALE=1000, T=150):
 *   max|X_cos| = 150 × 100 × 1000 = 15,000,000 < 2^24
 *   power < 2 × (15M)² ≈ 2^49  → GreaterThan(49) を使用
 *
 * テーブル仕様 (Fs=5.0Hz):
 *   COS_TABLE[f][t] = round(cos(2π × (0.155 + f×0.01) × t / 5.0) × 1000)
 *   SIN_TABLE[f][t] = round(sin(2π × (0.155 + f×0.01) × t / 5.0) × 1000)
 *
 * 周波数マッピング (0.01Hz刻みビン):
 *   bin  0 → 0.155Hz ≈ 0.15Hz  ← NORMAL_LOW_BIN
 *   bin 35 → 0.505Hz ≈ 0.50Hz  ← NORMAL_HIGH_BIN
 *   bin 44 → 0.595Hz ≈ 0.60Hz
 */

