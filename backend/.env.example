# データベース設定
DATABASE_URL=postgresql://csi_user:csi_password@localhost:5432/csi_system
DATABASE_USER=csi_user
DATABASE_PASSWORD=csi_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=csi_system

# Redis設定
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT設定
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API設定
API_V2_PREFIX=/api/v2
PROJECT_NAME=CSI Respiratory Monitoring System
VERSION=2.5.0
DESCRIPTION=Wi-Fi CSI based respiratory monitoring platform

# CORS設定
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# ログ設定
LOG_LEVEL=INFO

# セキュリティ設定
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_UPLOAD=10/minute

# 開発・デバッグ設定
DEBUG=True
TESTING=False
ENABLE_TEST_ENDPOINTS=True

# 研究モード設定
# RESEARCH_MODE=true: CSIデータを保存（研究・分析用）
# RESEARCH_MODE=false: CSIデータを保存せず、ZKP証明のみ保存（本番環境・プライバシー重視）
RESEARCH_MODE=true

# ZKP設定
# ZKP_AUTO_GENERATE: ZKP証明を自動生成するかどうか
ZKP_AUTO_GENERATE=true

# ZKP_AUTO_COMPILE: 初回起動時に回路を自動コンパイルするかどうか
# true=自動コンパイル（開発環境推奨）、false=手動コンパイル（本番環境推奨）
# 注意: 自動コンパイルには30分〜数時間かかる可能性があります
ZKP_AUTO_COMPILE=true

# ZKP_DATA_RETENTION_HOURS: ZKP生成後のデータ保持時間（時間単位）
# 0=即削除、>0=指定時間後削除、-1=削除しない（研究モードでのみ推奨）
ZKP_DATA_RETENTION_HOURS=0

# ブロックチェーン設定
ETHEREUM_RPC_URL=http://localhost:8545
ZKPROOF_CONTRACT_ADDRESS=
ZKPROOF_VERIFIER_CONTRACT_ADDRESS=
BLOCKCHAIN_PRIVATE_KEY=
