# データベース設定
DATABASE_URL=postgresql://csi_user:csi_password@localhost:5432/csi_system
DATABASE_USER=csi_user
DATABASE_PASSWORD=csi_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=csi_system

# Redis設定
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT設定
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API設定
API_V2_PREFIX=/api/v2
PROJECT_NAME=CSI Respiratory Monitoring System
VERSION=2.5.0
DESCRIPTION=Wi-Fi CSI based respiratory monitoring platform

# CORS設定
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# ログ設定
LOG_LEVEL=INFO

# IPFS設定（既存システム連携用）
IPFS_HOST=localhost
IPFS_PORT=5001
IPFS_GATEWAY_PORT=8080

# Blockchain設定（既存システム連携用）
BLOCKCHAIN_NODE_HOST=localhost
BLOCKCHAIN_NODE_PORT=9000
ETHEREUM_RPC_URL=http://localhost:8545

# セキュリティ設定
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_UPLOAD=10/minute

# 開発・デバッグ設定
DEBUG=True
TESTING=False