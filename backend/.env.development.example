# ========================================
# 開発環境設定（Development Environment）
# ========================================

# データベース設定
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/csi_platform_dev

# Redis設定
REDIS_URL=redis://localhost:6379/0

# JWT認証設定
JWT_SECRET_KEY=development-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS設定
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ========================================
# ZKP設定（開発環境）
# ========================================

# ZKP有効化（開発: true推奨、デバッグ時はfalse可）
ZKP_ENABLED=true

# ZKP開発モード（開発: true - JavaScript/Python実装も併用可能）
ZKP_DEVELOPMENT_MODE=true

# JavaScript/Python直接計算の許可（開発: true - 精度比較・デバッグ用）
ALLOW_JS_SIMILARITY=true
ALLOW_PYTHON_SIMILARITY=true

# ========================================
# ロギング設定
# ========================================
LOG_LEVEL=DEBUG
LOG_FORMAT=plain

# ========================================
# パフォーマンス設定
# ========================================
MAX_WORKERS=2
ZKP_QUEUE_SIZE=10
ZKP_TIMEOUT_SECONDS=60

# ========================================
# 開発専用機能
# ========================================

# ZKP精度比較レポート生成
ZKP_GENERATE_COMPARISON_REPORT=true

# ZKP証明の自動検証ログ出力
ZKP_VERBOSE_VERIFICATION=true

# 開発用エンドポイント有効化
ENABLE_DEV_ENDPOINTS=true
