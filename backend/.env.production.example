# ========================================
# 本番環境設定（Production Environment）
# ========================================

# データベース設定
DATABASE_URL=postgresql://user:password@postgres:5432/csi_platform

# Redis設定
REDIS_URL=redis://redis:6379/0

# JWT認証設定
JWT_SECRET_KEY=your-production-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS設定
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========================================
# ZKP設定（本番環境）
# ========================================

# ZKP有効化（本番: 必須true）
ZKP_ENABLED=true

# ZKP開発モード（本番: 必須false）
ZKP_DEVELOPMENT_MODE=false

# JavaScript/Python直接計算の許可（本番: 必須false）
ALLOW_JS_SIMILARITY=false
ALLOW_PYTHON_SIMILARITY=false

# ========================================
# ロギング設定
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================================
# パフォーマンス設定
# ========================================
MAX_WORKERS=4
ZKP_QUEUE_SIZE=100
ZKP_TIMEOUT_SECONDS=30
