# ========================================
# 本番環境用設定テンプレート
# ========================================
# 使用方法: このファイルを .env.production にコピーして、各値を本番環境用に置き換えてください

# ============================================
# 🔴 CRITICAL: セキュリティ設定（必ず変更）
# ============================================

# JWT設定（必ず強力なランダムキーに変更）
# 生成方法: openssl rand -base64 32
JWT_SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# データベース設定（必ず変更してください）
DATABASE_URL=postgresql://csi_user:CHANGE_THIS_PASSWORD@postgres:5432/csi_system
DATABASE_USER=csi_user
DATABASE_PASSWORD=CHANGE_THIS_PASSWORD
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=csi_system

# PostgreSQL管理者パスワード（必ず変更してください）
POSTGRES_USER=csi_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=csi_system

# Redis設定
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# 🔴 CORS設定（本番ドメインに制限）
# ============================================
# 本番環境では必ず特定ドメインのみ許可してください
ALLOWED_ORIGINS=["https://your-domain.com", "https://app.your-domain.com"]

# ============================================
# API設定
# ============================================
API_V2_PREFIX=/api/v2
PROJECT_NAME=CSI Respiratory Monitoring System
VERSION=2.5.0
DESCRIPTION=Wi-Fi CSI based respiratory monitoring platform

# ============================================
# 🔴 セキュリティ・機能制御
# ============================================
# 本番環境では必ずFalseに設定
DEBUG=False
TESTING=False
ENABLE_TEST_ENDPOINTS=False

# レート制限（必要に応じて調整）
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_UPLOAD=10/minute

# ============================================
# ログ設定
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# IPFS設定（既存システム連携用）
# ============================================
IPFS_HOST=ipfs
IPFS_PORT=5001
IPFS_GATEWAY_PORT=8080

# ============================================
# Blockchain設定（既存システム連携用）
# ============================================
BLOCKCHAIN_NODE_HOST=ganache
BLOCKCHAIN_NODE_PORT=8545
ETHEREUM_RPC_URL=http://ganache:8545

# ============================================
# ZKP設定
# ============================================
ZKP_ENABLED=true
ZKP_DEVELOPMENT_MODE=false
ALLOW_JS_SIMILARITY=false
ALLOW_PYTHON_SIMILARITY=false

# パフォーマンス設定
MAX_WORKERS=4
ZKP_QUEUE_SIZE=100
ZKP_TIMEOUT_SECONDS=30

# ============================================
# 本番デプロイ前チェックリスト
# ============================================
# [ ] JWT_SECRET_KEY を強力なランダムキーに変更
# [ ] DATABASE_PASSWORD を複雑なパスワードに変更
# [ ] POSTGRES_PASSWORD を複雑なパスワードに変更
# [ ] ALLOWED_ORIGINS を本番ドメインのみに制限
# [ ] DEBUG=False に設定
# [ ] ENABLE_TEST_ENDPOINTS=False に設定
# [ ] LOG_LEVEL を適切なレベルに設定（INFO推奨）
