# ==========================================
# CSI Web Platform - Frontend Environment Variables
# ==========================================
#
# IMPORTANT: Copy this file to .env.local and fill in the actual values
# NEVER commit .env.local to version control
#

# ==========================================
# 🔐 API Configuration - REQUIRED IN PRODUCTION
# ==========================================
# Example: http://localhost:8000 or https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time communication
# Example: ws://localhost:8000/api/v2/ws/realtime or wss://api.example.com/api/v2/ws/realtime
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v2/ws/realtime

# ==========================================
# Application Settings
# ==========================================
NEXT_PUBLIC_APP_NAME="CSI Respiratory Monitoring System"
NEXT_PUBLIC_APP_VERSION="2.5.0"

# ==========================================
# Development Settings
# ==========================================
# Set to 'true' to enable debug mode
NEXT_PUBLIC_DEBUG=false
