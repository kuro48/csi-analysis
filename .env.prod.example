# プロダクション環境用設定ファイル

# データベース設定
DATABASE_USER=csi_user
DATABASE_PASSWORD=secure_password_change_me
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=csi_system

# Redis設定
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_password

# JWT設定 (必ず変更してください)
JWT_SECRET_KEY=please-change-this-secret-key-in-production

# URL設定 (実際のドメインに変更してください)
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# SSL設定
SSL_CERT_PATH=/path/to/your/cert.pem
SSL_KEY_PATH=/path/to/your/key.pem

# 外部サービス設定
IPFS_HOST=ipfs
IPFS_PORT=5001
BLOCKCHAIN_NODE_HOST=localhost
ETHEREUM_RPC_URL=http://localhost:8545

# セキュリティ設定
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_API=1000/minute
RATE_LIMIT_UPLOAD=50/minute

# ログ設定
LOG_LEVEL=INFO
DEBUG=False